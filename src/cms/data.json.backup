  "causesFaqs": [
    {
      "question": "How are funds allocated?",
      "answer": "100% of public donations go directly to the designated cause. Operational costs are covered by private investors."
    },
    {
      "question": "Can I track my impact?",
      "answer": "Yes, every donor receives a personalized impact report showing exactly where and how their contribution was used."
    },
    {
      "question": "Is my donation tax-deductible?",
      "answer": "Absolutely. We are a verified 501(c)(3) organization. You will receive an instant tax receipt via email."
    },
    {
      "question": "How do you select missions?",
      "answer": "Our field teams conduct rigorous assessments to identify high-need areas where our resources can create the most sustainable long-term value."
    }
  ],
