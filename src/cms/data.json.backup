  "successStories": [
    {
      "id": 1,
      "slug": "from-beneficiary-to-entrepreneur",
      "title": "From Beneficiary to Entrepreneur",
      "name": "Amina Begum",
      "category": "Women Empowerment",
      "color": "rose",
      "region": "Barisal Sector",
      "story": "Amina joined our women's empowerment program three years ago with no source of income. Through vocational training and microfinance support, she started her own tailoring business.",
      "fullStory": "<p>Amina's journey began with a single sewing machine. After 6 months of training in our vocational center, she received a micro-grant to purchase equipment. Today, she runs a collaborative workshop that employs 5 other women, creating a micro-economy within her village. Her success demonstrates the multiplier effect of targeted empowerment.</p>",
      "impact": "5 jobs created",
      "year": "2023",
      "image": "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=2069",
      "videoUrl": "",
      "videoType": "",
      "order": 1
    },
    {
      "id": 2,
      "slug": "a-doctors-journey",
      "title": "A Doctor's Journey",
      "name": "Rashid Ahmed",
      "category": "Education",
      "color": "blue",
      "region": "Sylhet Node",
      "story": "Rashid was one of our first scholarship recipients in 2015. Despite financial hardships, he excelled in his studies. Today, he is a medical doctor serving in rural areas.",
      "fullStory": "<p>Rashid walked 5 kilometers to school every day. Recognizing his potential, Birdsfly Sangstha provided a full scholarship for his medical studies. He now heads our mobile clinic unit in Sylhet, treating over 200 patients monthly. He is the embodiment of our 'pay it forward' philosophy.</p>",
      "impact": "200+ patients/mo",
      "year": "2024",
      "image": "https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?q=80&w=2070",
      "videoUrl": "https://www.youtube.com/embed/dQw4w9WgXcQ",
      "videoType": "youtube",
      "order": 2
    },
    {
      "id": 3,
      "slug": "village-transformation",
      "title": "Village Transformation",
      "name": "Karimpur Village",
      "category": "Community Development",
      "color": "emerald",
      "region": "Khulna District",
      "story": "Karimpur was struggling with lack of clean water and basic healthcare. Through our integrated development program, we installed water systems and established a health clinic.",
      "fullStory": "<p>The transformation of Karimpur is a case study in integrated development. By simultaneously addressing water security, healthcare, and education, we saw a synergistic effect. Waterborne diseases dropped to near zero, and school attendance reached 100%. The village committee now sustainably manages these resources.</p>",
      "impact": "500 lives improved",
      "year": "2025",
      "image": "https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?q=80&w=2070",
      "videoUrl": "",
      "videoType": "",
      "order": 3
    }
  ],
