  "missionVision": {
    "missionTitle": "Our Mission",
    "missionDescription": "BirdsFly Sangstha is dedicated to building resilience, sustainability, and social justice in Bangladesh's coastal communities. We work across multiple sectors—climate resilience, WASH, agriculture, health, education, and empowerment—to directly impact vulnerable populations and create lasting change.",
    "missionPoints": [
      { "text": "Climate Change & Disaster Risk Reduction" },
      { "text": "Water, Sanitation & Hygiene (WASH)" },
      { "text": "Sustainable Agriculture & Food Security" },
      { "text": "Public Health & Nutrition" }
    ],
    "missionImage": "https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?q=80&w=2070",
    "visionTitle": "Our Vision",
    "visionDescription": "We envision coastal communities where every individual has access to clean water, sustainable livelihoods, quality education, and the opportunity to thrive despite climate challenges. A future where social justice, environmental sustainability, and human dignity are realities for all.",
    "visionPoints": [
      { "text": "Women Empowerment & Gender Equality" },
